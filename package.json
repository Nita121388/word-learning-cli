{
  "name": "word-learning-cli-workspace",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm --filter @word-learning/core build && pnpm -r check",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "pack:cli": "mkdir -p dist/cli && cd packages/cli && pnpm pack --pack-destination ../../dist/cli",
    "pack:plugin": "pnpm --filter @word-learning/obsidian-plugin build && node scripts/package-obsidian-plugin.mjs",
    "release:dry": "changeset version --snapshot dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.10.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
