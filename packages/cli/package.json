{
  "name": "@word-learning/cli",
  "version": "0.1.3",
  "type": "module",
  "bin": {
    "wordcli": "./dist/main.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json --emitDeclarationOnly && node esbuild.config.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@word-learning/core": "workspace:*",
    "commander": "^14.0.2",
    "esbuild": "^0.28.0"
  }
}
